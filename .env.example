# ─────────────────────────────────────────────────────────────
# F.I.R.E — Supabase configuration
# Copy this file to `.env.local` and fill in values from your
# Supabase project dashboard (Project Settings → API).
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser.
# Used by the seed script and privileged admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — base URL used for share links / redirects and email links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Deadline reminders + notifications (Phase 4) — server-only
# ─────────────────────────────────────────────────────────────
# Required for the reminders cron (/api/cron/reminders). Must match the
# Authorization: Bearer <CRON_SECRET> header. Use any long random string.
CRON_SECRET=your-long-random-string
# Resend API key for reminder emails. If unset, in-app notifications still
# fire but emails are skipped. https://resend.com
RESEND_API_KEY=your-resend-api-key
# From address for reminder emails (a Resend-verified sender/domain).
REMINDER_FROM_EMAIL=F.I.R.E <reminders@yourdomain.com>
