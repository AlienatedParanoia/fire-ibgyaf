# ─────────────────────────────────────────────────────────────
# F.I.R.E — Supabase configuration
# Copy this file to `.env.local` and fill in values from your
# Supabase project dashboard (Project Settings → API).
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser.
# Used by the seed script and privileged admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — base URL used for share links / redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
